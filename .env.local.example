# ============================================================
# FreelancerPT — Variáveis de Ambiente
# Copiar para .env.local e preencher com os teus valores
# NUNCA fazer commit do .env.local
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Em https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend (emails transacionais) ────────────────────────────
# Em https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=alertas@freelancerpt.app

# ── LemonSqueezy (pagamentos) ────────────────────────────────
# Em https://app.lemonsqueezy.com → Settings → API
LEMONSQUEEZY_API_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9...
LEMONSQUEEZY_WEBHOOK_SECRET=webhook_secret_xxxxxxxxxxxx
NEXT_PUBLIC_LEMONSQUEEZY_STORE_ID=12345
NEXT_PUBLIC_LEMONSQUEEZY_PRODUCT_MENSAL=67890   # ID do variant mensal €9
NEXT_PUBLIC_LEMONSQUEEZY_PRODUCT_ANUAL=67891    # ID do variant anual €79

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Em produção: NEXT_PUBLIC_APP_URL=https://freelancerpt.app
